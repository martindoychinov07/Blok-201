APP_NAME=dementia-edge-mvp
APP_ENV=dev
DATABASE_PATH=./data/mvp.db
TRANSCRIPT_DATABASE_PATH=./data/transcript_analysis.db
DEMO_MODE=false
DEFAULT_PATIENT_ID=patient-001
DEFAULT_DEVICE_ID=device-001
INGEST_SHARED_KEY=dev-ingest-key
GEOFENCE_EXIT_CONFIRMATIONS=2
GEOFENCE_COOLDOWN_SEC=120
FALL_IMPACT_G_THRESHOLD=2.5
FALL_INACTIVITY_SEC=20
NOTIFY_TELEGRAM_ENABLED=false
NOTIFY_TELEGRAM_BOT_TOKEN=
NOTIFY_TELEGRAM_CHAT_ID=
DEMO_TRANSCRIPT_INTERVAL_SEC=8
DEMO_GPS_INTERVAL_SEC=5
DEMO_ACCEL_INTERVAL_SEC=1

# Gemini transcript analysis backend
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash
GEMINI_TIMEOUT_SEC=25
GEMINI_FALLBACK_ENABLED=true

# Optional outbound webhook integration (forward AI analysis payloads)
ANALYSIS_WEBHOOK_ENABLED=false
ANALYSIS_WEBHOOK_URL=http://localhost:5000/api/ai/transcript-analysis
ANALYSIS_WEBHOOK_TIMEOUT_SEC=5
ANALYSIS_WEBHOOK_BEARER_TOKEN=

# Local WAV transcription (faster-whisper)
TRANSCRIPTION_MODEL=tiny
TRANSCRIPTION_DEVICE=cpu
TRANSCRIPTION_COMPUTE_TYPE=int8
TRANSCRIPTION_LANGUAGE=
MAX_AUDIO_UPLOAD_MB=20
